package main

import (
	"github.com/miyamo2/braider/pkg/annotation"
	"pkgcollision/v1user"
	user2 "pkgcollision/v2user"
)

var _ = annotation.App(main) // want "bootstrap code is missing"

func main() {
	_ = dependency
}

// braider:hash:63745fb1f7f82456
var dependency = func() struct {
	repository user.Repository
	service    *user.Service
	handler    *user2.Handler
} {
	repository := user.NewRepository()
	service := user.NewService(repository)
	handler := user2.NewHandler(repository)
	return struct {
		repository user.Repository
		service    *user.Service
		handler    *user2.Handler
	}{
		repository: repository,
		service:    service,
		handler:    handler,
	}
}()
