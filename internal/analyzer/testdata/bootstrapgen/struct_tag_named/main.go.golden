package main

import (
	"github.com/miyamo2/braider/pkg/annotation"
	"struct_tag_named/repository"
	"struct_tag_named/service"
)

var _ = annotation.App(main) // want "bootstrap code is missing"

func main() {
	_ = dependency
}

// braider:hash:6a11b58c8cd42100
var dependency = func() struct {
	appService *service.AppService
} {
	primaryRepo := repository.NewUserRepository()
	appService := service.NewAppService(primaryRepo)
	return struct {
		appService *service.AppService
	}{
		appService: appService,
	}
}()
