package main

import (
	"github.com/miyamo2/braider/pkg/annotation"
	"github.com/miyamo2/braider/pkg/annotation/app"
	"provide_typed/domain"
	"provide_typed/repository"
	"provide_typed/service"
)

var _ = annotation.App[app.Default](main) // want "bootstrap code is missing"

func main() {
	_ = dependency
}

// braider:hash:cbbcdb5657c83bb2
var dependency = func() struct {
	userRepository domain.IRepository
	userService    *service.UserService
} {
	userRepository := repository.NewUserRepository()
	userService := service.NewUserService(userRepository)
	return struct {
		userRepository domain.IRepository
		userService    *service.UserService
	}{
		userRepository: userRepository,
		userService:    userService,
	}
}()
