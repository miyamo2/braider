var _ = annotation.App[app.Default](main) // want "bootstrap code is missing"

func main() {
	_ = dependency
}

// braider:hash:00a86fc632256129
var dependency = func() struct {
	client *ext.Client
} {
	client := provider.NewClient()
	return struct {
		client *ext.Client
	}{
		client: client,
	}
}()
