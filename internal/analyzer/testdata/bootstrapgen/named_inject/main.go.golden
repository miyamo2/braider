package main

import (
	"github.com/miyamo2/braider/pkg/annotation"
	"github.com/miyamo2/braider/pkg/annotation/app"
	"named_inject/service"
)

var _ = annotation.App[app.Default](main) // want "bootstrap code is missing"

func main() {
	_ = dependency
}

// braider:hash:43fcf607076e4e65
var dependency = func() struct {
	primaryDB   *service.PrimaryDB
	secondaryDB *service.SecondaryDB
} {
	primaryDB := service.NewPrimaryDB()
	secondaryDB := service.NewSecondaryDB()
	return struct {
		primaryDB   *service.PrimaryDB
		secondaryDB *service.SecondaryDB
	}{
		primaryDB:   primaryDB,
		secondaryDB: secondaryDB,
	}
}()
